        <!-- rotate_1 — мини-схема СПРАВА от ветки расшифрования (поскольку шифрование слева, ответвление вправо для шифр-rot1 — далеко, делаем общую схему для всех вызовов) -->
        <!-- Размещаем мини-схемы rotate_1 и rotate_2 в крайней правой колонке -->

        <mxCell id="r1_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=13;" value="Вспомогательная функция rotate_1:&#xa;Поворот зеркально по горизонтали" vertex="1">
          <mxGeometry x="2400" y="1900" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r1_start" parent="1" style="ellipse;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=12;" value="Начало" vertex="1">
          <mxGeometry x="2510" y="1970" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r1_init" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Создание пустой&#xa;новой решётки new_matrix" vertex="1">
          <mxGeometry x="2440" y="2050" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r1_loop_s" parent="1" style="shape=mxgraph.flowchart.loop_limit;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Цикл по номерам строк&#xa;от 0 до len(trafar)−1" vertex="1">
          <mxGeometry x="2440" y="2130" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_rev" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Добавить в new_matrix&#xa;строку trafar[row] в обратном порядке&#xa;(row[::-1])" vertex="1">
          <mxGeometry x="2440" y="2215" width="260" height="65" as="geometry" />
        </mxCell>
        <mxCell id="r1_loop_e" parent="1" style="shape=mxgraph.flowchart.loop_limit;flipV=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Конец цикла по номерам строк" vertex="1">
          <mxGeometry x="2440" y="2310" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_ret" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Возврат new_matrix" vertex="1">
          <mxGeometry x="2440" y="2395" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r1_end" parent="1" style="ellipse;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=12;" value="Конец" vertex="1">
          <mxGeometry x="2510" y="2475" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="er1_s_i" edge="1" parent="1" source="r1_start" target="r1_init" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1_i_ls" edge="1" parent="1" source="r1_init" target="r1_loop_s" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1_ls_rev" edge="1" parent="1" source="r1_loop_s" target="r1_rev" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1_rev_le" edge="1" parent="1" source="r1_rev" target="r1_loop_e" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1_le_ret" edge="1" parent="1" source="r1_loop_e" target="r1_ret" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er1_ret_end" edge="1" parent="1" source="r1_ret" target="r1_end" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Пунктирные ответвления к rotate_1 от всех точек вызова -->
        <mxCell id="dash_enc_rot1" edge="1" parent="1" source="enc_rot1a" target="r1_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dash_enc_rot3" edge="1" parent="1" source="enc_rot3a" target="r1_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dash_dec_rot1" edge="1" parent="1" source="dec_rot1" target="r1_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dash_dec_rot3" edge="1" parent="1" source="dec_rot3" target="r1_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- rotate_2 — мини-схема -->
        <mxCell id="r2_title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=13;" value="Вспомогательная функция rotate_2:&#xa;Поворот по вертикали" vertex="1">
          <mxGeometry x="2850" y="1900" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="r2_start" parent="1" style="ellipse;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=12;" value="Начало" vertex="1">
          <mxGeometry x="2970" y="1970" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r2_init" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Создание пустой&#xa;новой решётки new_matrix" vertex="1">
          <mxGeometry x="2890" y="2050" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r2_loop_s" parent="1" style="shape=mxgraph.flowchart.loop_limit;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Цикл по номерам строк row&#xa;от 0 до len(trafar)−1" vertex="1">
          <mxGeometry x="2890" y="2130" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_pick" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Добавить в new_matrix строку&#xa;trafar[5 − row]&#xa;(зеркальная по вертикали)" vertex="1">
          <mxGeometry x="2890" y="2215" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="r2_loop_e" parent="1" style="shape=mxgraph.flowchart.loop_limit;flipV=1;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Конец цикла по номерам строк" vertex="1">
          <mxGeometry x="2890" y="2310" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r2_ret" parent="1" style="rounded=0;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=11;" value="Возврат new_matrix" vertex="1">
          <mxGeometry x="2890" y="2395" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r2_end" parent="1" style="ellipse;fillColor=#ffffff;strokeColor=#000000;fontStyle=1;fontSize=12;" value="Конец" vertex="1">
          <mxGeometry x="2970" y="2475" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="er2_s_i" edge="1" parent="1" source="r2_start" target="r2_init" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2_i_ls" edge="1" parent="1" source="r2_init" target="r2_loop_s" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2_ls_p" edge="1" parent="1" source="r2_loop_s" target="r2_pick" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2_p_le" edge="1" parent="1" source="r2_pick" target="r2_loop_e" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2_le_ret" edge="1" parent="1" source="r2_loop_e" target="r2_ret" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="er2_ret_end" edge="1" parent="1" source="r2_ret" target="r2_end" style="edgeStyle=orthogonalEdgeStyle;html=1;"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Пунктирные ответвления к rotate_2 -->
        <mxCell id="dash_enc_rot2" edge="1" parent="1" source="enc_rot2a" target="r2_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="dash_dec_rot2" edge="1" parent="1" source="dec_rot2" target="r2_title" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=classic;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
